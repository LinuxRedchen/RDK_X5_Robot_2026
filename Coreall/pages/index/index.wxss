/* 通用样式 */
.page-container {
    padding: 20rpx;
  }
  .head{
    display: flex;
    padding-top: 120rpx;
  }
  .flex{
    display: flex;
  }
  .weather{
    /* box-shadow: 0 8rpx  20rpx 0 rgba(0, 0, 0, 0.1); */
    box-shadow: #d6d6d6 0 0 8rpx;
    height: 250rpx;
    border-radius: 32rpx;
    margin: 38rpx 40rpx;
    background-color: white;
  }
  .weather_image_view{
    display: flex;
    width: 40%;
    align-items: center;
  }
  .weather_image{
    width: 200rpx;
    margin-left: 50rpx;
  }
  .weather_info_view{
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-left: 50rpx;
  }
  .location_view{
    margin-top: 40rpx;
  }
  .location_image{
    width: 24rpx;
  }
  .location_info{
    font-size: 24rpx;
    margin-left: 20rpx;
  }
  .temp_info{
    font-size: 70rpx;
    margin-top: 10rpx;
  }
  .wind_info{
    font-size: 24rpx;
    margin-top: 10rpx;
  }
  .header-container{
    background-color: #3d7ef9;
    color: #fff;
    border-radius: 36rpx;
    padding: 32rpx 64rpx;
  }
  .header-container .header-1{
    display: flex;
    justify-content: space-between;
    font-size: 28rpx;
  }
  .header-container .header-2{
    display: flex;
    justify-content: space-between;
    font-size: 64rpx;
  }
  .header-container .header-3{
    margin-top: 36rpx;
    font-size: 24rpx;
  }
  
  /* 数据项通用样式 */
  .data-container,
  .light-control-container {
    margin-top: 36rpx;
    display: grid;
    justify-content: center;
    grid-template-columns: repeat(auto-fill, 300rpx);
    grid-gap: 36rpx;
  }
  
  .data-item {
    position: relative;
    background-color: #fff;
    height: 180rpx;
    box-shadow: #d6d6d6 0 0 8rpx;
    border-radius: 36rpx;
    display: flex;
    justify-content: space-between;
  }
  
  .data-item .data-text {
    position: absolute;
    top: 36rpx;
    right: 24rpx;
    text-align: right;
    white-space: nowrap;
  }
  
  .data-item .data-picture {
    position: absolute;
    height: 96rpx;
    width: 96rpx;
    left: 16rpx;
    top: 16rpx;
    margin-top: 15rpx;
  }
  /* 时间显示样式 */
  .time-display {
    font-size: 24rpx;
    color: #888;
    text-align: center;
    margin-left: 15rpx;
    margin-top: 125rpx;
  }
  .data-item .data-title {
    font-size: 28rpx;
    color: #7f7f7f;
  }
  
  .data-item .data-value {
    font-size: 52rpx;
    font-weight: bold;
    color: #7f7f7f;
  }
  
  /* 特定数据项样式 */
  .light-control-container {
    grid-template-columns: repeat(auto-fill, 635rpx);
  }
  
  .light-control-container .data-item .data-text {
    width: 75%;
    text-align: center;
  }
  
  
  /**************************************************************************************/
  /* 参数设置容器 - 卡片式设计 */
  .settings-container {
    padding: 32rpx;
    margin: 32rpx;
    background-color: #fff;
    border-radius: 24rpx;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  }
  
  /* 标题样式 */
  .settings-title {
    font-size: 36rpx;
    font-weight: 600;
    color: #333;
    padding-bottom: 24rpx;
    margin-bottom: 24rpx;
    border-bottom: 2rpx solid #f0f0f0;
    position: relative;
  }
  
  .settings-title::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2rpx;
    width: 80rpx;
    height: 4rpx;
    background: #3d77ff;
    border-radius: 2rpx;
  }
  
  /* 设置项样式 */
  .setting-item {
    display: flex;
    align-items: center;
    padding: 28rpx 0;
    border-bottom: 1rpx dashed #eee;
    transition: all 0.3s;
  }
  
  .setting-item:active {
    background-color: #f8faff;
  }
  
  /* 标签文字 */
  .setting-label {
    font-size: 30rpx;
    color: #333;
    width: 30%;
    font-weight: 500;
  }
  
  /* 滑动条容器 */
  .setting-control {
    width: 100%;
    display: flex;
    align-items: center;
  }
  
  /* 自定义滑动条样式 */
  .custom-slider {
    display: flex;
    align-items: center;
    width: 100%;
  }
  
  .slider-track {
    position: relative;
    height: 25rpx; /* 轨道高度 */
    background: #e0e0e0;
    border-radius: 8rpx;
    flex: 1;
  }
  
  .slider-active {
    position: absolute;
    height: 100%;
    background: #3d77ff;
    border-radius: 8rpx;
  }
  
  .slider-thumb {
    position: absolute;
    width: 40rpx;
    height: 40rpx;
    background: #3d77ff;
    border-radius: 50%;
    top: 50%;
    transform: translateY(-50%);
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
    z-index: 2;
  }
  
  /* 数值显示 */
  .setting-value {
    margin-left: 24rpx;
    font-size: 30rpx;
    font-weight: 500;
    color: #3d77ff;
    min-width: 80rpx;
    text-align: center;
  }
  
  /* 保存按钮 */
  .save-button {
    margin-top: 24rpx;
    padding: 24rpx;
    background: linear-gradient(90deg, #3d77ff, #5a8cff);
    color: white;
    text-align: center;
    border-radius: 16rpx;
    font-size: 32rpx;
    font-weight: 500;
    box-shadow: 0 4rpx 12rpx rgba(61, 119, 255, 0.2);
    transition: all 0.2s;
  }
  
  .save-button:active {
    transform: scale(0.85);
    opacity: 0.9;
  }